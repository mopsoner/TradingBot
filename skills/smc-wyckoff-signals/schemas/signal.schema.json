    "timeframe_context",
    "pattern",
    "direction",
    "liquidity_zone",
    "sweep_level",
    "displacement",
    "bos_level",
    "fib_entry_zone",
    "entry_zone",
    "stop_loss",
    "targets",
    "setup_valid"
  ],
  "properties": {
