      "type": "string"
    },
    "timeframe_context": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pattern": {
      "type": "string",
      "enum": [
        "spring",
        "utad",
        "none"
      ]
    },
    "direction": {
      "type": "string",
      "enum": [
