        "short",
        "none"
      ]
    },
    "liquidity_zone": {
      "type": "object"
    },
    "sweep_level": {
      "type": "number"
    },
    "displacement": {
      "type": "boolean"
    },
    "bos_level": {
      "type": "number"
    },
    "fib_entry_zone": {
      "type": "object"
    },
    "entry_zone": {
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "stop_loss": {
      "type": "number"
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "setup_valid": {
      "type": "boolean"
    },
    "confidence": {
      "type": "number"
    }
