{
  "symbol_discovery": {
    "enabled": true,
    "quote_assets": ["USDT"],
    "status": "TRADING",
    "spot_only": true,
    "max_symbols_total": 250,
    "batch_size": 20,
    "batch_rotation_file": "data/batch_state.json"
  },
  "intervals": ["1m", "5m", "1h"],
  "poll_seconds": 45,
  "lookback_limit": 180,
  "rsi_period": 14,
  "swing_window": 5,
  "equal_level_tolerance_pct": 0.0015,
  "signals": {
    "overbought": 70,
    "oversold": 30,
    "price_near_extreme_pct": 0.003
  },
  "session_timezone_offset_hours": -4,
  "binance_rest_base": "https://data-api.binance.vision",
  "database_path": "data/signals.db",
  "ohlc_cache_db_path": "data/ohlc_cache.db",
  "log_path": "logs/market.log",
  "dashboard_path": "data/dashboard.json",
  "backtest_report_path": "data/backtest_report.json",
  "backtest_trades_path": "data/backtest_trades.json",
  "backtest": {
    "symbol": "ETHUSDT",
    "interval": "5m",
    "history_limit": 800,
    "holding_bars": 6,
    "min_score": 5
  }
}
